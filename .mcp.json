{
  "mcpServers": {
    "playwright": {
      "command": "sh",
      "args": [
        "-c",
        "DIR=/tmp/mcp-playwright-$(basename \"$PWD\" | tr ' ' '-') && echo '{\"browser\":{\"launchOptions\":{\"args\":[\"--guest\",\"--password-store=basic\",\"--disable-features=PasswordLeakDetection,PasswordManager\",\"--disable-background-networking\",\"--disable-sync\"]}}}' > /tmp/pw-mcp-config.json && npx -y @playwright/mcp@latest --config /tmp/pw-mcp-config.json --user-data-dir=\"$DIR\""
      ]
    },
    "chrome-devtools": {
      "command": "sh",
      "args": [
        "-c",
        "npx -y chrome-devtools-mcp@latest --userDataDir=/tmp/mcp-chrome-$(basename \"$PWD\" | tr ' ' '-')"
      ]
    }
  }
}
